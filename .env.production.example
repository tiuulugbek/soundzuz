COMPOSE_PROJECT_NAME=soundz
IMAGE_NAME=ghcr.io/tiuulugbek/soundzuz
IMAGE_TAG=latest

POSTGRES_DB=soundz
POSTGRES_USER=soundz
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DATABASE_PASSWORD
DATABASE_URL=postgresql://soundz:CHANGE_ME_STRONG_DATABASE_PASSWORD@postgres:5432/soundz
REDIS_URL=redis://redis:6379

JWT_ACCESS_SECRET=CHANGE_ME_AT_LEAST_32_RANDOM_CHARACTERS
CORS_ORIGINS=https://soundz.uz,https://www.soundz.uz,https://admin.soundz.uz
ADMIN_SEED_EMAIL=admin@soundz.uz
ADMIN_SEED_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD

NEXT_PUBLIC_API_URL=https://api.soundz.uz/v1
NEXT_PUBLIC_SITE_URL=https://soundz.uz
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_YANDEX_METRIKA_ID=

MEDIA_STORAGE_DRIVER=r2
MEDIA_S3_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
MEDIA_S3_REGION=auto
MEDIA_S3_BUCKET=soundz-media
MEDIA_S3_ACCESS_KEY_ID=CHANGE_ME
MEDIA_S3_SECRET_ACCESS_KEY=CHANGE_ME
MEDIA_PUBLIC_BASE_URL=https://media.soundz.uz
MEDIA_STORAGE_PATH=/app/storage/media

TELEGRAM_BOT_TOKEN=
TELEGRAM_LEADS_CHAT_ID=
OUTBOX_POLL_INTERVAL_MS=5000

WEB_DOMAIN=soundz.uz
ADMIN_DOMAIN=admin.soundz.uz
API_DOMAIN=api.soundz.uz
GRAFANA_ROOT_URL=https://monitor.soundz.uz
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_STRONG_GRAFANA_PASSWORD
ALERT_WEBHOOK_URL=
BACKUP_RETENTION_DAYS=14
