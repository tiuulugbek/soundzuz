generator client {
  provider = "prisma-client"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum LeadType {
  HEARING_AID_CONSULTATION
  PRICE_REQUEST
  APPOINTMENT_REQUEST
  IEM_CONSULTATION
  GENERAL_CONTACT
}

enum LeadStatus {
  NEW
  NEEDS_CONTACT
  CONTACTED
  APPOINTMENT_BOOKED
  FOLLOW_UP
  VISITED
  SALE_COMPLETED
  CANCELLED
  INVALID
}

enum Locale {
  uz
  ru
}

enum OutboxStatus {
  PENDING
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
  DEAD
}

enum NotificationChannel {
  TELEGRAM
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

model User {
  id                       String                     @id @default(cuid())
  email                    String                     @unique
  passwordHash             String
  firstName                String
  lastName                 String?
  status                   UserStatus                 @default(ACTIVE)
  roles                    UserRole[]
  assignedLeads            Lead[]                     @relation("AssignedLead")
  leadNotes                LeadNote[]
  statusChanges            LeadStatusHistory[]
  auditLogs                AuditLog[]
  appointmentStatusChanges AppointmentStatusHistory[]
  createdAt                DateTime                   @default(now())
  updatedAt                DateTime                   @updatedAt
}

model Role {
  id        String     @id @default(cuid())
  code      String     @unique
  name      String
  userRoles UserRole[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model UserRole {
  userId String
  roleId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model Branch {
  id           String          @id @default(cuid())
  name         String
  slug         String          @unique
  phone        String?
  address      String?
  isActive     Boolean         @default(true)
  leads        Lead[]
  schedules    BranchSchedule[]
  closures     BranchClosure[]
  services     BranchService[]
  appointments Appointment[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
}

model Contact {
  id              String        @id @default(cuid())
  name            String
  normalizedPhone String        @unique
  displayPhone    String
  email           String?
  leads           Lead[]
  appointments    Appointment[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([name])
}

model Lead {
  id              String              @id @default(cuid())
  publicReference String              @unique
  idempotencyKey  String?             @unique
  contactId       String
  contact         Contact             @relation(fields: [contactId], references: [id], onDelete: Restrict)
  type            LeadType
  status          LeadStatus          @default(NEW)
  locale          Locale              @default(uz)
  branchId        String?
  branch          Branch?             @relation(fields: [branchId], references: [id], onDelete: SetNull)
  assignedUserId  String?
  assignedUser    User?               @relation("AssignedLead", fields: [assignedUserId], references: [id], onDelete: SetNull)
  productId       String?
  serviceId       String?
  message         String?
  preferredAt     DateTime?
  sourceUrl       String?
  referrer        String?
  utmSource       String?
  utmMedium       String?
  utmCampaign     String?
  utmContent      String?
  utmTerm         String?
  statusHistory   LeadStatusHistory[]
  notes           LeadNote[]
  appointment     Appointment?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([status, createdAt])
  @@index([branchId, createdAt])
  @@index([assignedUserId, status])
}

model LeadStatusHistory {
  id          String     @id @default(cuid())
  leadId      String
  lead        Lead       @relation(fields: [leadId], references: [id], onDelete: Cascade)
  fromStatus  LeadStatus?
  toStatus    LeadStatus
  changedById String?
  changedBy   User?      @relation(fields: [changedById], references: [id], onDelete: SetNull)
  note        String?
  createdAt   DateTime   @default(now())

  @@index([leadId, createdAt])
}

model LeadNote {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Restrict)
  body      String
  createdAt DateTime @default(now())

  @@index([leadId, createdAt])
}

model OutboxEvent {
  id             String                 @id @default(cuid())
  type           String
  aggregateType  String
  aggregateId    String
  idempotencyKey String                 @unique
  payload        Json
  status         OutboxStatus           @default(PENDING)
  attempts       Int                    @default(0)
  availableAt    DateTime               @default(now())
  lockedAt       DateTime?
  processedAt    DateTime?
  lastError      String?
  deliveries     NotificationDelivery[]
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  @@index([status, availableAt])
}

model NotificationDelivery {
  id                String              @id @default(cuid())
  outboxEventId     String
  outboxEvent       OutboxEvent         @relation(fields: [outboxEventId], references: [id], onDelete: Cascade)
  channel           NotificationChannel
  destination       String
  status            NotificationStatus  @default(PENDING)
  providerMessageId String?
  attempts          Int                 @default(0)
  lastError         String?
  sentAt            DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@unique([outboxEventId, channel, destination])
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  actorUser   User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  action      String
  entityType  String
  entityId    String
  before      Json?
  after       Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([entityType, entityId, createdAt])
  @@index([actorUserId, createdAt])
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CONTACTED
  ARRIVED
  NO_SHOW
  CANCELLED
  RESCHEDULED
  COMPLETED
}

enum AppointmentCreatedBy {
  PUBLIC
  ADMIN
  TELEGRAM
}

model Service {
  id              String          @id @default(cuid())
  code            String          @unique
  name            String
  description     String?
  durationMinutes Int             @default(30)
  isActive        Boolean         @default(true)
  branchServices  BranchService[]
  appointments    Appointment[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model BranchSchedule {
  id          String   @id @default(cuid())
  branchId    String
  branch      Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  weekday     Int
  openMinute  Int
  closeMinute Int
  isClosed    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([branchId, weekday])
}

model BranchClosure {
  id        String   @id @default(cuid())
  branchId  String
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  date      DateTime @db.Date
  reason    String?
  createdAt DateTime @default(now())

  @@unique([branchId, date])
}

model BranchService {
  branchId     String
  serviceId    String
  branch       Branch  @relation(fields: [branchId], references: [id], onDelete: Cascade)
  service      Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  isActive     Boolean @default(true)
  slotCapacity Int     @default(1)

  @@id([branchId, serviceId])
}

model Appointment {
  id            String                     @id @default(cuid())
  publicReference String                   @unique
  idempotencyKey String?                   @unique
  leadId         String                    @unique
  lead           Lead                      @relation(fields: [leadId], references: [id], onDelete: Restrict)
  contactId      String
  contact        Contact                   @relation(fields: [contactId], references: [id], onDelete: Restrict)
  branchId       String
  branch         Branch                    @relation(fields: [branchId], references: [id], onDelete: Restrict)
  serviceId      String
  service        Service                   @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  startsAt       DateTime
  endsAt         DateTime
  status         AppointmentStatus         @default(PENDING)
  createdBy      AppointmentCreatedBy      @default(PUBLIC)
  note           String?
  statusHistory  AppointmentStatusHistory[]
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt

  @@index([branchId, startsAt, status])
  @@index([contactId, startsAt])
}

model AppointmentStatusHistory {
  id            String             @id @default(cuid())
  appointmentId String
  appointment   Appointment        @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  fromStatus    AppointmentStatus?
  toStatus      AppointmentStatus
  changedById   String?
  changedBy     User?              @relation(fields: [changedById], references: [id], onDelete: SetNull)
  note          String?
  createdAt     DateTime           @default(now())

  @@index([appointmentId, createdAt])
}

model MediaAsset {
  id              String         @id
  originalName    String         @map("original_name")
  mimeType        String         @map("mime_type")
  width           Int
  height          Int
  altText         String?        @map("alt_text")
  caption         String?
  storageProvider String         @default("local") @map("storage_provider")
  variants        MediaVariant[]
  usages          MediaUsage[]
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  @@map("media_assets")
}

model MediaVariant {
  id         String     @id
  mediaId    String     @map("media_id")
  media      MediaAsset @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  variantKey String     @map("variant_key")
  width      Int
  height     Int
  sizeBytes  Int        @map("size_bytes")
  path       String
  url        String
  createdAt  DateTime   @default(now()) @map("created_at")

  @@unique([mediaId, variantKey])
  @@index([mediaId])
  @@map("media_variants")
}

model MediaUsage {
  id         String     @id
  mediaId    String     @map("media_id")
  media      MediaAsset @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  entityType String     @map("entity_type")
  entityId   String     @map("entity_id")
  slot       String
  sortOrder  Int        @default(0) @map("sort_order")
  createdAt  DateTime   @default(now()) @map("created_at")

  @@unique([entityType, entityId, slot, sortOrder], map: "media_usages_entity_slot_order_key")
  @@index([entityType, entityId, slot], map: "media_usages_entity_idx")
  @@map("media_usages")
}

model Product {
  id               String   @id
  slug             String   @unique
  locale           String   @default("uz")
  name             String
  shortDescription String?  @map("short_description")
  description      String?
  brand            String?
  formFactor       String?  @map("form_factor")
  technologyLevel  String?  @map("technology_level")
  priceFrom        Decimal? @map("price_from")
  priceTo          Decimal? @map("price_to")
  rechargeable     Boolean  @default(false)
  bluetooth        Boolean  @default(false)
  inStock          Boolean  @default(true) @map("in_stock")
  isFeatured       Boolean  @default(false) @map("is_featured")
  status           String   @default("DRAFT")
  seoTitle         String?  @map("seo_title")
  seoDescription   String?  @map("seo_description")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@index([status, locale], map: "products_status_locale_idx")
  @@index([brand, formFactor], map: "products_brand_form_idx")
  @@map("products")
}

model CatalogTaxonomy {
  id        String   @id
  type      String
  value     String
  label     String
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([type, value])
  @@index([type, isActive, sortOrder], map: "catalog_taxonomies_type_active_idx")
  @@map("catalog_taxonomies")
}
