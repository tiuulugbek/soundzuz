# Application runtime
NODE_ENV=development
PORT=4000
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:4000/v1

# Source website migration
SOURCE_BASE_URL=https://soundz.uz
MIGRATION_OUTPUT_DIR=./data/migration
HTTP_TIMEOUT_MS=20000
HTTP_USER_AGENT=SoundzMigrationBot/0.2 (+https://soundz.uz)

# PostgreSQL
POSTGRES_DB=soundz
POSTGRES_USER=soundz
POSTGRES_PASSWORD=change-me-locally
DATABASE_URL=postgresql://soundz:change-me-locally@localhost:5432/soundz?schema=public

# Redis
REDIS_URL=redis://localhost:6379
OUTBOX_POLL_INTERVAL_MS=5000

# Media storage
# local: development uchun. r2 yoki s3: production uchun.
MEDIA_STORAGE_DRIVER=local
MEDIA_STORAGE_PATH=./storage/media
MEDIA_S3_ENDPOINT=http://localhost:9000
MEDIA_S3_REGION=us-east-1
MEDIA_S3_BUCKET=soundz-media
MEDIA_S3_ACCESS_KEY_ID=soundz
MEDIA_S3_SECRET_ACCESS_KEY=change-me-minio
MEDIA_PUBLIC_BASE_URL=http://localhost:9000/soundz-media

# MinIO local development
MINIO_ROOT_USER=soundz
MINIO_ROOT_PASSWORD=change-me-minio

# Cloudflare R2 production misoli:
# MEDIA_STORAGE_DRIVER=r2
# MEDIA_S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# MEDIA_S3_REGION=auto
# MEDIA_S3_BUCKET=soundz-media
# MEDIA_S3_ACCESS_KEY_ID=
# MEDIA_S3_SECRET_ACCESS_KEY=
# MEDIA_PUBLIC_BASE_URL=https://media.soundz.uz

# Telegram — developmentda bo‘sh qolsa worker konsol preview qiladi
TELEGRAM_BOT_TOKEN=
TELEGRAM_LEADS_CHAT_ID=

# Authentication
JWT_ACCESS_SECRET=replace-with-at-least-32-random-characters
ADMIN_SEED_EMAIL=admin@soundz.uz
ADMIN_SEED_PASSWORD=ChangeMe123!
SEED_DEMO_DATA=false

# Public URLs
APP_BASE_URL=http://localhost:3000
ADMIN_BASE_URL=http://localhost:3001
API_BASE_URL=http://localhost:4000
