{
  "name": "soundz-cpanel-web",
  "version": "0.2.0",
  "private": true,
  "description": "Soundz Next.js frontend packaged for cPanel Passenger hosting",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "dev": "next dev apps/web -p 3000",
    "build": "next build apps/web",
    "start": "node server.js",
    "typecheck": "tsc --noEmit -p apps/web/tsconfig.json"
  },
  "dependencies": {
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@types/node": "^24.0.15",
    "@types/react": "^19.1.9",
    "@types/react-dom": "^19.1.7",
    "typescript": "^5.9.2"
  }
}
